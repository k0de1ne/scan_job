# --- HeadHunter API (OAuth) ---
# Получите на https://dev.hh.ru/
HH_CLIENT_ID=your_client_id_here
HH_CLIENT_SECRET=your_client_secret_here

# --- LLM Proxy Configuration ---
# Адрес вашего OpenAI-совместимого прокси-сервера
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL_NAME=gpt-3.5-turbo

# --- Auth Server (HH Python Backend) ---
# Адрес сервера для обхода ограничений OAuth (Phone/SMS)
HH_AUTH_BASE_URL=http://localhost:8000

# --- Security ---
# Случайная строка для генерации подписей запросов (X-Signature)
APP_SALT=generate_a_random_string_here
